{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YoloLauncher",
  "version": "0.7.0",
  "identifier": "com.yololauncher.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YoloLauncher",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["Russian", "English"],
        "displayLanguageSelector": true,
        "installMode": "currentUser"
      }
    },
    "publisher": "YoloLauncher Team",
    "copyright": "Copyright © 2026 YoloLauncher",
    "category": "Game",
    "shortDescription": "YoloLauncher — The Ultimate Minecraft Launcher",
    "longDescription": "YoloLauncher — удобный лаунчер для Minecraft с поддержкой аккаунтов, модов, скинов и многого другого."
  }
}
